# PhotoFlow Configuration
# Copy this file to .env and adjust values

# === Required ===
DB_PASSWORD=change_me_strong_password
SECRET_KEY=change_me_very_long_random_string_at_least_32_chars

# === Photos ===
PHOTOS_PATH=/mnt/media-8tb/Fotos

# === Server ===
PORT=8090
LOG_LEVEL=INFO
WORKER_CONCURRENCY=4

# === AI Providers (all optional) ===
# Gemini
GEMINI_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Anthropic Claude
ANTHROPIC_API_KEY=

# Ollama (local LLM)
OLLAMA_URL=http://localhost:11434
