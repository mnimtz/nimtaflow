# exiftool user-defined tags for NimtaFlow — registers the custom XMP namespace
# `nimtaflow` so custom tags land in the sidecar with the correct URI instead
# of being silently dropped as "unknown". Loaded via `exiftool -config <this>`.
%Image::ExifTool::UserDefined = (
    'Image::ExifTool::XMP::Main' => {
        nimtaflow => {
            SubDirectory => {
                TagTable => 'Image::ExifTool::UserDefined::nimtaflow',
            },
        },
    },
);
%Image::ExifTool::UserDefined::nimtaflow = (
    GROUPS        => { 0 => 'XMP', 1 => 'XMP-nimtaflow', 2 => 'Image' },
    NAMESPACE     => { 'nimtaflow' => 'http://nimtaflow.com/xmp/1.0/' },
    WRITABLE      => 'string',
    # Full structured description as compact JSON — survives DB loss, portable
    # across other apps (they treat it as an opaque XMP string).
    StructuredDesc => { },
    # Free-form JSON dump of who was recognised in this photo (Face-Regions in
    # MWG-rs already covers name+bbox; this can carry richer future data).
    Recognised     => { },
);
1;  # required so Perl "use" of the config file succeeds
